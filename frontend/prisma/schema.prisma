model Inquiry {
  id            String   @id @default(uuid())
  firstName     String   @default("")
  lastName      String   @default("")
  phone         String   @default("")
  email         String?
  service       String   @default("")
  source        String   @default("")
  priority      String   @default("Routine")
  status        String   @default("New")
  followUp      String   @default("")
  notes         String?
  appointmentId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PatientDocument {
  id          String   @id
  uhid        String   @default("")
  name        String   @default("")
  type        String   @default("")
  uploadedBy  String   @default("")
  uploadedOn  String   @default("")
  verified    Boolean  @default(false)
  updatedBy   String?
  updatedAt   String?
  createdAt   DateTime @default(now())
  patientName String?  @default("")
  fileSize    Int?
  storagePath String?
  patients    Patient  @relation(fields: [uhid], references: [uhid], onDelete: Cascade)
}

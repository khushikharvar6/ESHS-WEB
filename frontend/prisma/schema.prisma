generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  password   String
  role       String    @default("FRONT_DESK")
  department String?
  firstName  String    @map("first_name")
  lastName   String    @map("last_name")
  phone      String?
  avatarUrl  String?
  isActive   Boolean   @default(true) @map("is_active")
  lastLogin  DateTime? @map("last_login_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Patient {
  uhid                       String            @id @unique @default(dbgenerated("gen_random_uuid()"))
  firstName                  String            @default("")
  lastName                   String            @default("")
  gender                     String            @default("")
  mobileNo                   String            @default("")
  bloodGroup                 String?
  maritalStatus              String?
  city                       String?
  state                      String?
  pincode                    String?
  createdAt                  DateTime          @default(now())
  dob                        String?
  updatedAt                  String?
  age                        Int               @default(0)
  alternateMobile            String?
  appointmentId              String?
  assignedDepartment         String?
  assignedDepartmentServices String?
  careType                   String?
  country                    String            @default("India")
  emailAddress               String?
  emergencyContactName       String?
  emergencyPhoneNumber       String?
  emergencyRelationship      String?
  initials                   String            @default("")
  inquiryId                  String?
  lastVisit                  String            @default("")
  middleName                 String?
  patientCategory            String?
  registeredOn               String            @default("")
  residentialAddress         String?
  salutation                 String            @default("")
  service                    String            @default("")
  status                     String            @default("Active")
  updatedBy                  String?
  vip                        Boolean           @default(false)
  appointments               Appointment[]
  consultations              Consultation[]
  invoices                   Invoice[]
  nonConformances            NonConformance[]
  PatientDocument            PatientDocument[]
  feedbacks                  Feedback[]
  corporate                  PatientCorporate?
  insurance                  PatientInsurance?

  @@index([uhid])
  @@index([mobileNo])
  @@map("patients")
}

model PatientInsurance {
  id                String   @id @default(uuid())
  patientUhid       String   @unique
  policyNumber      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  firstName         String?
  insuranceContact  String?
  insuranceNotes    String?
  insuranceProvider String?
  lastName          String?
  tpaNetwork        String?
  patient           Patient  @relation(fields: [patientUhid], references: [uhid], onDelete: Cascade)

  @@map("patient_insurance")
}

model PatientCorporate {
  id               String   @id @default(uuid())
  patientUhid      String   @unique
  companyName      String?
  employeeId       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  companyContact   String?
  corporateAddress String?
  corporateId      String?
  firstName        String?
  lastName         String?
  patient          Patient  @relation(fields: [patientUhid], references: [uhid], onDelete: Cascade)

  @@map("patient_corporate")
}

model Doctor {
  id              String         @id
  firstName       String
  lastName        String
  fullName        String
  specialization  String[]
  qualification   String?
  experienceYears Int?
  phone           String?
  email           String?
  consultationFee Decimal        @default(0)
  followUpFee     Decimal        @default(0)
  isActive        Boolean        @default(true)
  bio             String?
  avatarUrl       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  appointments    Appointment[]
  consultations   Consultation[]
}

model Appointment {
  id        String   @id @default(uuid())
  firstName String   @default("")
  lastName  String   @default("")
  phone     String   @default("")
  email     String?
  doctor    String   @default("")
  service   String   @default("")
  date      String   @default("")
  time      String   @default("")
  type      String   @default("")
  notes     String?
  status    String   @default("Scheduled")
  inquiryId String?
  uhid      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctorId  String?
  doctorRef Doctor?  @relation(fields: [doctorId], references: [id])
  patient   Patient? @relation(fields: [uhid], references: [uhid], onDelete: Cascade)
}

model Consultation {
  id             String   @id @default(uuid())
  uhid           String   @default("")
  doctor         String   @default("")
  service        String   @default("")
  date           String   @default("")
  chiefComplaint String   @default("")
  diagnosis      String   @default("")
  treatmentNotes String?
  prescription   String?
  followUp       String?
  files          String[]
  updatedBy      String?
  updatedAt      String?
  createdAt      DateTime @default(now())
  doctorId       String?
  vitals         Json?
  medicines      Json?
  doctorRef      Doctor?  @relation(fields: [doctorId], references: [id])
  patient        Patient  @relation(fields: [uhid], references: [uhid], onDelete: Cascade)
}

model Invoice {
  id            String   @id @default(uuid())
  uhid          String?
  patient       String   @default("")
  service       String   @default("")
  date          String   @default("")
  subtotal      Decimal  @default(0)
  tax           Decimal  @default(0)
  discount      Decimal  @default(0)
  total         Decimal  @default(0)
  paid          Decimal  @default(0)
  balance       Decimal  @default(0)
  status        String   @default("Draft")
  paymentMode   String?
  transactionId String?
  remarks       String?
  updatedBy     String?
  updatedAt     String?
  createdAt     DateTime @default(now())
  patientRef    Patient? @relation(fields: [uhid], references: [uhid])
}

model NonConformance {
  id              String   @id @default(uuid())
  uhid            String   @default("")
  patient         String   @default("")
  relatedDocument String   @default("")
  department      String   @default("")
  severity        String   @default("Minor")
  status          String   @default("Open")
  dueDate         String   @default("")
  assignedTo      String   @default("")
  description     String?
  rootCause       String?
  title           String?
  updatedBy       String?
  updatedAt       String?
  createdAt       DateTime @default(now())
  patientRef      Patient  @relation(fields: [uhid], references: [uhid])
}

model ServiceMaster {
  id         String   @id
  department String   @unique @default("DOCTOR_CONSULTATION")
  name       String   @default("Unknown Service")
  price      Decimal  @default(0)
  taxRate    Decimal  @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("service_masters")
}

model TestMaster {
  id           String        @id
  itemType     String        @default("TEST")
  category     String        @default("Uncategorized")
  subcategory  String?
  serviceType  String?
  department   String        @default("DOCTOR_CONSULTATION")
  name         String        @default("Unknown Test")
  price        Decimal       @default(0)
  taxRate      Decimal       @default(0)
  sourceUrl    String        @default("https://eshealth.in/")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  packageItems PackageItem[]

  @@unique([name, category])
  @@map("test_masters")
}

model PackageMaster {
  id          String        @id
  name        String        @unique @default("Unknown Package")
  description String?
  price       Decimal       @default(0)
  taxRate     Decimal       @default(0)
  isActive    Boolean       @default(true)
  sourceUrl   String        @default("https://eshealthcarecentre.in/packages")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
  items       PackageItem[]

  @@map("package_masters")
}

model PackageItem {
  id        String        @id @default(uuid())
  packageId String
  testId    String?
  itemName  String
  quantity  Int           @default(1)
  createdAt DateTime      @default(now())
  package   PackageMaster @relation(fields: [packageId], references: [id], onDelete: Cascade)
  test      TestMaster?   @relation(fields: [testId], references: [id])

  @@index([packageId])
}

model Feedback {
  id                        String                       @id @default(uuid())
  uhid                      String
  patientName               String
  service                   String
  heardAbout                String?
  referenceBy               String?
  serviceAvailed            String?
  overallRating             Int
  staffAppreciated          String?
  positiveComments          String?
  negativeComments          String?
  agreeToUsage              Boolean                      @default(true)
  createdAt                 DateTime                     @default(now())
  cardiologyRatings         FeedbackCardiology[]
  dayCareRatings            FeedbackDayCare[]
  doctorConsultationRatings FeedbackDoctorConsultation[]
  generalRatings            FeedbackGeneral[]
  homeHealthcareRatings     FeedbackHomeHealthcare[]
  ipdRatings                FeedbackIPD[]
  ophthalmologyRatings      FeedbackOphthalmology[]
  packageRatings            FeedbackPackage[]
  pathologyRatings          FeedbackPathology[]
  pharmacyRatings           FeedbackPharmacy[]
  physiotherapyRatings      FeedbackPhysiotherapy[]
  pulmonologyRatings        FeedbackPulmonology[]
  radiologyRatings          FeedbackRadiology[]
  patient                   Patient                      @relation(fields: [uhid], references: [uhid], onDelete: Cascade)

  @@map("feedbacks")
}

model FeedbackHomeHealthcare {
  id         String   @id @default(uuid())
  uhid       String?
  feedbackId String
  question   String
  rating     Int
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@map("feedback_home_healthcare")
}

